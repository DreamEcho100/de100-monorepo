{
	"name": "@de100/monorepo",
	"private": true,
	"engines": {
		"node": "^23.7.0",
		"pnpm": "^11.1.2"
	},
	"packageManager": "pnpm@11.1.2",
	"scripts": {
		"build": "turbo run build",
		"clean": "git clean -xdf node_modules",
		"clean:workspaces": "turbo run clean",
		"dev": "turbo watch dev --continue",
		"format-and-lint:check": "turbo run format-and-lint:check --continue -- && pnpm lint:error-i18n && pnpm lint:media-storage-coupling",
		"format-and-lint:fix": "turbo run format-and-lint:fix --continue --",
		"format:check": "turbo run format:check --continue --",
		"format:fix": "turbo run format:fix --continue --",
		"lint:check": "turbo run lint:check --continue -- && pnpm lint:error-i18n && pnpm lint:media-storage-coupling",
		"lint:error-i18n": "node ./scripts/check-localized-error-literals.mjs",
		"lint:media-storage-coupling": "node ./scripts/check-media-storage-coupling.mjs",
		"lint:fix": "turbo run lint:fix --continue --",
		"lint:ws": "pnpm dlx sherif@latest",
		"test": "turbo run test --continue --filter=@de100/apps-lms-web --filter=@de100/apps-lms-api --filter=@de100/apps-lms-auth --filter=@de100/apps-lms-db --filter=@de100/apps-lms-cache --filter=@de100/apps-lms-validators --filter=@de100/i18n-domains-solidjs --filter=@de100/ui-solidjs",
		"test:watch": "turbo run test:watch --continue --filter=@de100/apps-lms-web --filter=@de100/apps-lms-api --filter=@de100/apps-lms-auth --filter=@de100/apps-lms-db --filter=@de100/apps-lms-cache --filter=@de100/apps-lms-validators --filter=@de100/i18n-domains-solidjs --filter=@de100/ui-solidjs",
		"type:check": "turbo run type:check --continue --",
		"postinstall": "pnpm lint:ws",
		"ui-add": "turbo run ui-add"
	},
	"devDependencies": {
		"@biomejs/biome": "catalog:",
		"@de100/biome-config": "workspace:*",
		"@turbo/gen": "^2.9.14",
		"dotenv-cli": "catalog:",
		"turbo": "^2.9.14",
		"typescript": "catalog:",
		"ultracite": "catalog:"
	}
}
