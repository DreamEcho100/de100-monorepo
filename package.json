{
	"name": "@de100/monorepo",
	"private": true,
	"engines": {
		"node": "^23.7.0",
		"pnpm": "^11.1.2"
	},
	"packageManager": "pnpm@11.1.2",
	"scripts": {
		"build": "turbo run build",
		"clean": "git clean -xdf node_modules",
		"clean:workspaces": "turbo run clean",
		"dev": "turbo watch dev --continue",
		"format-and-lint:check": "turbo run format-and-lint:check --continue -- && pnpm lint:workspace-package-scripts",
		"format-and-lint:fix": "turbo run format-and-lint:fix --continue --",
		"format:check": "turbo run format:check --continue --",
		"format:fix": "turbo run format:fix --continue --",
		"lint:check": "turbo run lint:check --continue -- && pnpm lint:workspace-package-scripts",
		"lint:workspace-package-scripts": "node ./scripts/check-package-scripts.mjs",
		"lint:fix": "turbo run lint:fix --continue --",
		"lint:ws": "pnpm dlx sherif@latest",
		"test": "turbo run test --continue",
		"test:watch": "turbo run test:watch --continue",
		"type:check": "tsc -p tsconfig.json --noEmit && turbo run type:check --continue --",
		"postinstall": "pnpm lint:ws"
	},
		"devDependencies": {
		"@biomejs/biome": "catalog:",
		"@de100/biome-config": "workspace:*",
		"@turbo/gen": "^2.9.16",
		"@types/node": "catalog:",
		"dotenv-cli": "catalog:",
		"turbo": "^2.9.16",
		"typescript": "catalog:",
		"ultracite": "catalog:"
	}
}
