{
	"name": "@de100/monorepo",
	"private": true,
	"engines": {
		"node": "^23.7.0",
		"pnpm": "^11.1.2"
	},
	"packageManager": "pnpm@11.1.2",
	"scripts": {
		"build": "turbo run build",
		"clean": "git clean -xdf node_modules",
		"clean:workspaces": "turbo run clean",
		"auth:generate": "pnpm -F @de100/auth generate",
		"db:push": "turbo -F @de100/db-proto push",
		"db:studio": "turbo -F @de100/db-proto studio",
		"dev": "turbo watch dev --continue",
		"dev:next": "turbo watch dev -F @de100/nextjs...",
		"format-and-lint:check": "turbo run format-and-lint:check --continue --",
		"format-and-lint:fix": "turbo run format-and-lint:fix --continue --",
		"format:check": "turbo run format:check --continue --",
		"format:fix": "turbo run format:fix --continue --",
		"lint:check": "turbo run lint:check --continue --",
		"lint:fix": "turbo run lint:fix --continue --",
		"lint:ws": "pnpm dlx sherif@latest",
		"type:check": "turbo run type:check --continue --",
		"postinstall": "pnpm lint:ws",
		"ui-add": "turbo run ui-add",
		"android": "expo run:android",
		"ios": "expo run:ios"
	},
	"devDependencies": {
		"@biomejs/biome": "catalog:",
		"@de100/biome-config": "workspace:*",
		"@turbo/gen": "^2.9.12",
		"dotenv-cli": "^11.0.0",
		"turbo": "^2.9.12",
		"typescript": "catalog:",
		"ultracite": "catalog:"
	}
}
