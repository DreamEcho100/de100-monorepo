{
	"$schema": "https://json.schemastore.org/tsconfig",
	"extends": "./base.json",
	"compilerOptions": {
		"declaration": true,
		"declarationMap": true,
		"emitDeclarationOnly": true,
		"noEmit": false,
		"outDir": "${configDir}/dist",
		"allowJs": true,
		"checkJs": true
	},
	"exclude": ["node_modules", "dist"]
}
