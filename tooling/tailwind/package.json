{
	"name": "@de100/tailwind-config",
	"private": true,
	"type": "module",
	"exports": {
		"./theme": "./theme.css",
		"./postcss-config": "./postcss-config.js"
	},
	"license": "MIT",
	"scripts": {
		"clean": "git clean -xdf .cache .turbo node_modules",
		"format-and-lint:check": "biome check --config-path=\"./biome.json\" --css-parse-tailwind-directives=true .",
		"format-and-lint:fix": "biome check --config-path=\"./biome.json\" --css-parse-tailwind-directives=true  --write .",
		"format:check": "biome format --config-path=\"./biome.json\" --css-parse-tailwind-directives=true .",
		"format:fix": "biome format --config-path=\"./biome.json\" --css-parse-tailwind-directives=true --write .",
		"lint:check": "biome lint --config-path=\"./biome.json\" --css-parse-tailwind-directives=true .",
		"lint:fix": "biome lint --config-path=\"./biome.json\" --css-parse-tailwind-directives=true  --write .",
		"type:check": "tsc -p tsconfig.json --noEmit"
	},
	"dependencies": {
		"@tailwindcss/postcss": "catalog:",
		"postcss": "^8.5.6",
		"tailwindcss": "catalog:"
	},
	"devDependencies": {
		"@biomejs/biome": "catalog:",
		"@de100/biome-config": "workspace:*",
		"@de100/tsconfig": "workspace:*",
		"@types/node": "catalog:",
		"typescript": "catalog:"
	}
}
