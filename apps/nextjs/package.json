{
  "name": "@de100/nextjs",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm with-env next build",
    "clean": "git clean -xdf .cache .next .turbo node_modules",
    "dev": "pnpm with-env next dev",
    "start": "pnpm with-env next start",
    "format:check": "biome format --css-parse-tailwind-directives=true .",
    "format:fix": "biome format --css-parse-tailwind-directives=true --write .",
    "lint:check": "biome lint --css-parse-tailwind-directives=true .",
    "lint:fix": "biome lint --css-parse-tailwind-directives=true  --write .",
    "type:check": "tsc --noEmit",
    "with-env": "dotenv -e ../../.env --"
  },
  "dependencies": {
    "@de100/api-proto": "workspace:*",
    "@de100/auth-proto": "workspace:*",
    "@de100/db-proto": "workspace:*",
    "@de100/ui-proto": "workspace:*",
    "@de100/validators-proto": "workspace:*",
    "@t3-oss/env-nextjs": "^0.13.8",
    "@tanstack/react-form": "catalog:",
    "@tanstack/react-query": "catalog:",
    "@trpc/client": "catalog:",
    "@trpc/server": "catalog:",
    "@trpc/tanstack-react-query": "catalog:",
    "better-auth": "catalog:",
    "next": "^16.0.9",
    "react": "catalog:react19",
    "react-dom": "catalog:react19",
    "superjson": "2.2.3",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@de100/biome-config": "workspace:*",
    "@de100/tailwind-config": "workspace:*",
    "@de100/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "@types/react": "catalog:react19",
    "@types/react-dom": "catalog:react19",
    "jiti": "^2.5.1",
    "tailwindcss": "catalog:",
    "tw-animate-css": "^1.4.0",
    "typescript": "catalog:"
  }
}
