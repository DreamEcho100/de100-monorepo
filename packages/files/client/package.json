			"optional": true
		},
		"@uppy/file-input": {
			"optional": true
		},
		"@uppy/golden-retriever": {
			"optional": true
		},
		"@uppy/image-editor": {
			"optional": true
		},
		"@uppy/informer": {
			"optional": true
		},
		"@uppy/progress-bar": {
			"optional": true
		},
		"@uppy/remote-sources": {
			"optional": true
		},
		"@uppy/screen-capture": {
