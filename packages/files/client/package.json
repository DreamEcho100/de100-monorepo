		},
		"@uppy/xhr-upload": {
			"optional": true
		}
	},
	"devDependencies": {
		"@biomejs/biome": "catalog:",
		"@de100/biome-config": "workspace:*",
		"@de100/tsconfig": "workspace:*",
		"typescript": "catalog:",
		"vitest": "catalog:"
	}
}
