{
  "name": "@de100/validators-proto",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./src/index.ts"
    }
  },
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "dev": "tsc",
    "format:check": "biome format .",
    "format:fix": "biome format --css-parse-tailwind-directives=true --write .",
    "lint:check": "biome lint --css-parse-tailwind-directives=true .",
    "lint:fix": "biome lint --write .",
    "type:check": "tsc --noEmit --emitDeclarationOnly false"
  },
  "dependencies": {
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@de100/biome-config": "workspace:*",
    "@de100/tsconfig": "workspace:*",
    "typescript": "catalog:"
  }
}
