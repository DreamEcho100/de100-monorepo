{
	"name": "@de100/apps-proto-cook-api",
	"type": "module",
	"exports": {
		".": {
			"default": "./src/index.ts"
		},
		"./*": {
			"default": "./src/*.ts"
		}
	},
	"scripts": {
		"files:minio-smoke": "node ./scripts/files-minio-smoke.mjs",
		"test": "vitest run",
		"test:watch": "vitest",
		"clean": "git clean -xdf .cache .turbo dist node_modules",
		"format-and-lint:check": "biome check --config-path=\"./biome.json\" --css-parse-tailwind-directives=true . && pnpm lint:localized-errors && pnpm lint:files-storage-coupling",
		"format-and-lint:fix": "biome check --config-path=\"./biome.json\" --css-parse-tailwind-directives=true  --write . && pnpm lint:localized-errors && pnpm lint:files-storage-coupling",
		"format:check": "biome format --config-path=\"./biome.json\" --css-parse-tailwind-directives=true .",
		"format:fix": "biome format --config-path=\"./biome.json\" --css-parse-tailwind-directives=true --write .",
		"lint:check": "biome lint --config-path=\"./biome.json\" --css-parse-tailwind-directives=true . && pnpm lint:localized-errors && pnpm lint:files-storage-coupling",
		"lint:fix": "biome lint --config-path=\"./biome.json\" --css-parse-tailwind-directives=true  --write .",
		"lint:files-storage-coupling": "node ../../../../scripts/check-files-storage-coupling.mjs",
		"lint:localized-errors": "node ../../../../scripts/check-localized-error-literals.mjs",
		"type:check": "tsc -p tsconfig.json --noEmit",
		"ci:proto-cook:format-and-lint": "pnpm format-and-lint:check",
		"ci:proto-cook:type:check": "pnpm type:check",
		"ci:proto-cook:test": "pnpm test"
	},
	"dependencies": {
		"@aws-sdk/client-s3": "catalog:",
		"@aws-sdk/s3-request-presigner": "catalog:",
		"@de100/apps-proto-cook-auth": "workspace:*",
		"@de100/apps-proto-cook-db": "workspace:*",
		"@de100/apps-proto-cook-env": "workspace:*",
		"@de100/apps-proto-cook-validators": "workspace:*",
		"@de100/files-processing-video": "workspace:*",
		"@de100/files-server": "workspace:*",
		"@de100/files-shared": "workspace:*",
		"@orpc/client": "catalog:",
		"@orpc/openapi": "catalog:",
		"@orpc/server": "catalog:",
		"@types/pg": "^8.16.0",
		"dotenv": "catalog:",
		"drizzle-orm": "catalog:",
		"vitest": "catalog:",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@biomejs/biome": "catalog:",
		"@de100/apps-proto-cook-config": "workspace:*",
		"@de100/biome-config": "workspace:*",
		"@de100/tsconfig": "workspace:*",
		"typescript": "catalog:"
	}
}
