{
	"name": "@de100/apps-proto-cook-infra",
	"private": true,
	"type": "module",
	"exports": {
		".": {
			"default": "./src/index.ts"
		},
		"./*": {
			"default": "./src/*.ts"
		}
	},
	"scripts": {
		"dev": "pnpm selfhost:preflight",
		"deploy": "pnpm selfhost:verify",
		"destroy": "node ./scripts/selfhost-destroy-help.mjs",
		"selfhost:preflight": "node ./scripts/selfhost-preflight.mjs",
		"selfhost:health": "node ./scripts/selfhost-healthcheck.mjs",
		"selfhost:smoke:public": "node ./scripts/selfhost-smoke-public.mjs",
		"selfhost:smoke:hosted": "node ./scripts/selfhost-smoke-hosted.mjs",
		"selfhost:verify": "pnpm selfhost:preflight && pnpm selfhost:health",
		"selfhost:verify:full": "pnpm selfhost:verify && pnpm selfhost:smoke:public",
		"selfhost:evidence:init": "node ./scripts/selfhost-evidence-init.mjs",
		"clean": "git clean -xdf .cache .turbo dist node_modules",
		"format-and-lint:check": "biome check --config-path=\"./biome.json\" --css-parse-tailwind-directives=true .",
		"format-and-lint:fix": "biome check --config-path=\"./biome.json\" --css-parse-tailwind-directives=true  --write .",
		"format:check": "biome format --config-path=\"./biome.json\" --css-parse-tailwind-directives=true .",
		"format:fix": "biome format --config-path=\"./biome.json\" --css-parse-tailwind-directives=true --write .",
		"lint:check": "biome lint --config-path=\"./biome.json\" --css-parse-tailwind-directives=true .",
		"lint:fix": "biome lint --config-path=\"./biome.json\" --css-parse-tailwind-directives=true  --write .",
		"type:check": "tsc -p tsconfig.json --noEmit --emitDeclarationOnly false"
	},
	"dependencies": {
		"dotenv": "catalog:",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@biomejs/biome": "catalog:",
		"@de100/apps-proto-cook-config": "workspace:*",
		"@de100/biome-config": "workspace:*",
		"@de100/tsconfig": "workspace:*",
		"typescript": "catalog:"
	}
}
