{
	"name": "@de100/apps-lms-worker",
	"private": true,
	"type": "module",
	"exports": {
		".": {
			"default": "./src/index.ts"
		},
		"./*": {
			"default": "./src/*.ts"
		}
	},
	"license": "MIT",
	"scripts": {
		"test": "vitest run",
		"test:watch": "vitest",
		"test:ci": "vitest run",
		"build": "tsc -p tsconfig.json --noEmit --emitDeclarationOnly false",
		"clean": "git clean -xdf .cache .turbo dist node_modules",
		"format-and-lint:check": "biome check --config-path=\"./biome.json\" --css-parse-tailwind-directives=true .",
		"format-and-lint:fix": "biome check --config-path=\"./biome.json\" --css-parse-tailwind-directives=true --write .",
		"type:check": "tsc -p tsconfig.json --noEmit --emitDeclarationOnly false"
	},
	"dependencies": {
		"@de100/apps-lms-api": "workspace:*",
		"@de100/apps-lms-db": "workspace:*",
		"@de100/apps-lms-env": "workspace:*",
		"@de100/files-server": "workspace:*",
		"@de100/files-shared": "workspace:*",
		"drizzle-orm": "catalog:"
	},
	"devDependencies": {
		"@biomejs/biome": "catalog:",
		"@de100/apps-lms-config": "workspace:*",
		"@de100/biome-config": "workspace:*",
		"@de100/tsconfig": "workspace:*",
		"typescript": "catalog:",
		"vitest": "catalog:"
	}
}
