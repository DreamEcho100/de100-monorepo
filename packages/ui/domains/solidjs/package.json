{
	"name": "@de100/ui-domains-solidjs",
	"private": true,
	"type": "module",
	"exports": {
		".": {
			"default": "./src/index.ts"
		},
		"./*": {
			"default": "./src/*"
		}
	},
	"imports": {
		"#components/*": "./src/components/*",
		"#libs/*": "./src/libs/*",
		"#*": "./src/*"
	},
	"license": "MIT",
	"scripts": {
		"test": "vitest run",
		"test:watch": "vitest",
		"test:ci": "vitest run",
		"clean": "git clean -xdf .cache .turbo dist node_modules",
		"format-and-lint:check": "biome check --config-path=\"./biome.json\" --css-parse-tailwind-directives=true .",
		"format-and-lint:fix": "biome check --config-path=\"./biome.json\" --css-parse-tailwind-directives=true  --write .",
		"format:check": "biome format --config-path=\"./biome.json\" --css-parse-tailwind-directives=true .",
		"format:fix": "biome format --config-path=\"./biome.json\" --css-parse-tailwind-directives=true --write .",
		"lint:check": "biome lint --config-path=\"./biome.json\" --css-parse-tailwind-directives=true .",
		"lint:fix": "biome lint --config-path=\"./biome.json\" --css-parse-tailwind-directives=true  --write .",
		"type:check": "tsc -p tsconfig.json --noEmit --emitDeclarationOnly false",
		"ui-add": "pnpm dlx shadcn@latest add && biome format --write src"
	},
	"dependencies": {
		"@corvu/calendar": "^0.1.2",
		"@corvu/drawer": "^0.2.4",
		"@corvu/otp-field": "^0.1.4",
		"@corvu/resizable": "^0.2.5",
		"@de100/ui-shared": "workspace:*",
		"@kobalte/core": "^0.13.11",
		"@unpic/solid": "^1.0.0",
		"@uppy/core": "^5.2.0",
		"@uppy/dashboard": "^5.1.1",
		"@uppy/drag-drop": "^5.1.0",
		"@uppy/tus": "^5.1.1",
		"@uppy/webcam": "^5.1.0",
		"@uppy/xhr-upload": "^5.2.0",
		"class-variance-authority": "^0.7.1",
		"cmdk-solid": "^1.1.2",
		"date-fns": "^4.1.0",
		"echarts": "^6.0.0",
		"embla-carousel": "^8.6.0",
		"embla-carousel-solid": "^8.6.0",
		"js.foresight": "^3.5.0",
		"lucide-solid": "catalog:",
		"solid-js": "catalog:",
		"solid-sonner": "^0.3.1",
		"tailwindcss": "catalog:",
		"vite": "catalog:"
	},
	"devDependencies": {
		"@biomejs/biome": "catalog:",
		"@de100/biome-config": "workspace:*",
		"@de100/tsconfig": "workspace:*",
		"typescript": "catalog:",
		"vite-plugin-solid": "^2.11.12",
		"vitest": "catalog:",
		"zod": "catalog:"
	},
	"peerDependencies": {
		"zod": "catalog:"
	}
}
