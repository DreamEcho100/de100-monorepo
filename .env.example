# Since .env is gitignored, you can use .env.example to build a new `.env` file when you clone the repo.
# Keep this file up-to-date when you add new variables to \`.env\`.

# This file will be committed to version control, so make sure not to have any secrets in it.
# If you are cloning this repo, create a copy of this file named `.env` and populate it with your secrets.

# Optional local password for Alchemy state encryption when using the infra package.
# This is used by the deploy toolchain, not the app runtime itself.
# ALCHEMY_PASSWORD='replace-with-a-local-password'

# Database connection string.
# Use a local Docker/Postgres URI for development or replace this with your hosted provider URI.
APP_LMS_DATABASE_URL="postgres://postgres:postgres@127.0.0.1:5432/de100_lms"

# Optional explicit DB driver override.
# - auto: infer from APP_LMS_DATABASE_URL
# - postgres: use postgres.js (good for local Docker/Postgres)
# - neon-http: use the Neon HTTP driver
APP_LMS_DATABASE_DRIVER='auto'


# You can generate the secret via 'openssl rand -base64 32' on Unix
# @see https://www.better-auth.com/docs/installation
APP_LMS_BETTER_AUTH_SECRET='replace-with-a-32-character-secret'

# Better Auth base URL.
# Keep this on the auth route origin that serves /api/auth.
APP_LMS_BETTER_AUTH_URL='http://127.0.0.1:3000/api/auth'

# Allowed browser origin for auth + API requests.
APP_LMS_CORS_ORIGIN='http://127.0.0.1:3000'

# Optional explicit server URL for client-side auth/RPC calls.
# Leave empty when the browser talks to the same origin.
VITE_APP_LMS_SERVER_URL='http://127.0.0.1:3000'

# Optional Vite trace mode for local runtime debugging.
# Prefer setting this in `.env.trace.local` so normal development stays unchanged.
# - 1/true: keep names, enable client/server sourcemaps, and disable build minification
# - unset/0/false: use the normal app defaults
# LMS_APP_VITE_TRACE_MODE='1'

# Optional cache driver for Better Auth secondary storage.
# - memory: in-process cache for local/default development
# - redis: Redis over TCP, including the local Docker service below
# - upstash: Upstash Redis over HTTPS
APP_LMS_CACHE_DRIVER='memory'
APP_LMS_CACHE_KEY_PREFIX='de100:lms'

# Media storage backend.
# - r2: Cloudflare R2 via runtime bindings (production default)
# - local: local filesystem fallback for local development/testing
APP_LMS_MEDIA_STORAGE_DRIVER='r2'

# Local media root used when APP_LMS_MEDIA_STORAGE_DRIVER='local'.
# Can be absolute or relative to the current server process working directory.
APP_LMS_MEDIA_LOCAL_ROOT='./.local/media'

# Optional dedicated secret for signed media URLs.
# Leave unset to fall back to APP_LMS_BETTER_AUTH_SECRET.
# MEDIA_SIGNING_SECRET='replace-with-a-separate-32-character-secret'

# Signed media URL lifetime in seconds.
APP_LMS_MEDIA_SIGNED_URL_TTL_SECONDS='3600'

# Uncomment when APP_LMS_CACHE_DRIVER='redis'.
# REDIS_URL='redis://127.0.0.1:6379'

# Uncomment when APP_LMS_CACHE_DRIVER='upstash'.
# UPSTASH_REDIS_URL='https://your-upstash-instance.upstash.io'
# UPSTASH_REDIS_TOKEN='replace-with-your-upstash-token'

# 
APP_LMS_SERVER_PORT=3000
LMS_APP_VITE_TRACE_MODE=1